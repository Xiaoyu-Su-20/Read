{
  "name": "readr",
  "private": true,
  "version": "0.9.0-rc.6",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "build": "tsc && vite build",
    "build:rc": "tsc && vite build --mode rc",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:rc": "tauri build --config src-tauri/tauri.rc.conf.json",
    "test": "vitest run",
    "release:prepare:rc": "node scripts/prepare-rc-release.mjs",
    "release:prepare:rc:dry": "node scripts/prepare-rc-release.mjs --dry-run",
    "release:publish": "node scripts/publish-release.mjs",
    "release:publish:dry": "node scripts/publish-release.mjs --dry-run",
    "version": "npm run version:sync",
    "version:check": "node scripts/sync-version.mjs --check",
    "version:sync": "node scripts/sync-version.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
