{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "npm run dev:mobile",
    "beforeBuildCommand": "npm run build:mobile",
    "devUrl": "http://localhost:1421"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Readr Mobile",
        "width": 430,
        "height": 932,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "backgroundColor": "#f3eddf",
        "theme": "Light",
        "decorations": false,
        "shadow": false
      }
    ]
  }
}
